-- 1. Criação do Banco de Dados
DROP DATABASE IF EXISTS db_lgpd4devs;
CREATE DATABASE db_lgpd4devs CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE db_lgpd4devs;

-- 2. Tabela de Categorias (Organização do Checklist)
CREATE TABLE categorias (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    descricao TEXT
) ENGINE=InnoDB;

-- 3. Tabela de Usuários (Integrada com LoginPage.tsx / CadastroPage.tsx)
CREATE TABLE usuarios (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    senha VARCHAR(255) NOT NULL, -- Armazenar com password_hash no PHP
    data_cadastro TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

-- 4. Tabela de Perguntas (Coração do Sistema)
CREATE TABLE perguntas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    categoria_id INT NOT NULL,
    texto TEXT NOT NULL,
    peso INT DEFAULT 1, -- Para cálculo do Diagnóstico (UC03)
    FOREIGN KEY (categoria_id) REFERENCES categorias(id) ON DELETE CASCADE
) ENGINE=InnoDB;

-- 5. Tabela de Respostas (Persistência do Progresso)
CREATE TABLE respostas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    usuario_id INT NOT NULL,
    pergunta_id INT NOT NULL,
    resposta TINYINT NOT NULL, -- 1 para SIM, 0 para NÃO
    data_resposta TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (usuario_id) REFERENCES usuarios(id) ON DELETE CASCADE,
    FOREIGN KEY (pergunta_id) REFERENCES perguntas(id) ON DELETE CASCADE
) ENGINE=InnoDB;

-- 6. Tabela de Materiais de Apoio (Para o Diagnóstico Final)
CREATE TABLE materiais (
    id INT AUTO_INCREMENT PRIMARY KEY,
    pergunta_id INT NOT NULL,
    titulo VARCHAR(255) NOT NULL,
    url_referencia TEXT NOT NULL,
    FOREIGN KEY (pergunta_id) REFERENCES perguntas(id) ON DELETE CASCADE
) ENGINE=InnoDB;

